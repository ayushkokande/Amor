rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles: any signed-in user may read (needed for match/chat views);
    // only the owner may write, and never a password field.
    match /profiles/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && !request.resource.data.keys().hasAny(['password']);
      allow delete: if false;

      // Written by the server (admin SDK bypasses rules); clients read only.
      match /matches/{doc} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Waiting-pool buckets: users may enqueue themselves at signup.
    // Everything else is server-side.
    match /groupcount/{bucket}/users/{doc} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Groups: clients read their group and submit preferences.
    // TODO: move preference submission to the server, then drop `update`.
    match /groups/{id} {
      allow read, update: if request.auth != null;
      allow create, delete: if false;
    }

    // Chat rooms are handled by the socket server only.
    match /rooms/{id} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
